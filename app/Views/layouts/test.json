-4_bio_local\">\n  <div class=\"kb-row-column-wrap\">\n\n    <!-- wp:kadence/column {\"uniqueID\":\"4_bio_col1\",\"maxWidth\":700} -->\n    <div class=\"wp-block-kadence-column kadence-column-4_bio_col1\">\n      <div class=\"kt-inside-inner-col\" style=\"background-color:#4a7c1a;padding:40px;border-radius:8px\">\n\n        <!-- wp:kadence/advancedheading {\"uniqueID\":\"bio_subtitle\",\"align\":\"center\",\"color\":\"#c8e88a\",\"size\":14,\"sizeType\":\"px\",\"fontWeight\":\"400\",\"textTransform\":\"italic\"} -->\n        <p class=\"kt-adv-heading wp-block-kadence-advancedheading\" style=\"color:#c8e88a;font-size:14px;font-style:italic;text-align:center\">les Jardins de la Montagne Verte</p>\n        <!-- /wp:kadence/advancedheading -->\n\n        <!-- wp:kadence/advancedheading {\"uniqueID\":\"bio_title\",\"align\":\"center\",\"color\":\"#ffffff\",\"size\":28,\"sizeType\":\"px\",\"fontWeight\":\"700\"} -->\n        <h2 class=\"kt-adv-heading wp-block-kadence-advancedheading\" style=\"color:#ffffff;font-size:28px;font-weight:700;text-align:center\">Lieu de production Bio, Local & Solidaire</h2>\n        <!-- /wp:kadence/advancedheading -->\n\n        <!-- wp:paragraph {\"align\":\"center\",\"style\":{\"color\":{\"text\":\"#e0f0b0\"}}} -->\n        <p class=\"has-text-align-center\" style=\"color:#e0f0b0\">Depuis 2003, au service du maraîchage biologique, je vous accueille dans mon élan, les principes qui animent les Domaines Locaux ainsi que ceux du territoire. Nos valeurs sont simples : SI terres nourricières.</p>\n        <!-- /wp:paragraph -->\n\n        <!-- wp:paragraph {\"align\":\"center\",\"style\":{\"color\":{\"text\":\"#e0f0b0\"},\"typography\":{\"fontStyle\":\"italic\"}}} -->\n        <p class=\"has-text-align-center\" style=\"color:#e0f0b0;font-style:italic\">— Christophe</p>\n        <!-- /wp:paragraph -->\n\n      </div>\n    </div>\n    <!-- /wp:kadence/column -->\n\n  </div>\n</div>\n<!-- /wp:kadence/rowlayout -->\n\n<!-- wp:kadence/rowlayout {\"un