out -->\n\n<!-- wp:kadence/rowlayout {\"uniqueID\":\"7_saveurs_bio\",\"columns\":2,\"colLayout\":\"50-50\",\"bgColor\":\"#ffffff\",\"paddingTop\":60,\"paddingBottom\":60,\"paddingUnit\":\"px\"} -->\n<div class=\"wp-block-kadence-rowlayout kb-row-layout-wrap kadence-row-7_saveurs_bio\">\n  <div class=\"kb-row-column-wrap\">\n\n    <!-- wp:kadence/column {\"uniqueID\":\"7_saveurs_col_img\"} -->\n    <div class=\"wp-block-kadence-column kadence-column-7_saveurs_col_img\">\n      <div class=\"kt-inside-inner-col\">\n        <!-- wp:image {\"sizeSlug\":\"large\"} -->\n        <figure class=\"wp-block-image size-large\"><img src=\"REMPLACER_URL_IMAGE_CUISINE\" alt=\"Cuisiner avec les légumes Bio\"/></figure>\n        <!-- /wp:image -->\n      </div>\n    </div>\n    <!-- /wp:kadence/column -->\n\n    <!-- wp:kadence/column {\"uniqueID\":\"7_saveurs_col_text\"} -->\n    <div class=\"wp-block-kadence-column kadence-column-7_saveurs_col_text\">\n      <div class=\"kt-inside-inner-col\">\n\n        <!-- wp:kadence/advancedheading {\"uniqueID\":\"saveurs_pretitle\",\"color\":\"#90c940\",\"size\":13,\"sizeType\":\"px\",\"textTransform\":\"italic\"} -->\n        <p style=\"color:#90c940;font-size:13px;font-style:italic\">En savoir plus</p>\n        <!-- /wp:kadence/advancedheading -->\n\n        <!-- wp:kadence/advancedheading {\"uniqueID\":\"saveurs_title\",\"color\":\"#3a3a3a\",\"size\":26,\"sizeType\":\"px\",\"fontWeight\":\"700\"} -->\n        <h2 class=\"kt-adv-heading wp-block-kadence-advancedheading\" style=\"color:#3a3a3a;font-size:26px;font-weight:700\">La diversité des saveurs avec le Bio</h2>\n        <!-- /wp:kadence/advancedheading -->\n\n        <!-- wp:kadence/advancedheading {\"uniqueID\":\"saveurs_sub\",\"color\":\"#90c940\",\"size\":16,\"sizeType\":\"px\",\"fontWeight\":\"600\"} -->\n        <h3 class=\"kt-adv-heading wp-block-kadence-advancedheading\" style=\"color:#90c940;font-size:16px;font-weight:600\">Pourquoi choisir Bio ?</h3>\n        <!-- /wp:kadence/advancedheading -->\n\n        <!-- wp:list {\"style\":{\"color\":{\"text\":\"#555555\"}}} -->\n        <ul style=\"color:#555555\">\n          <li>Les fruits et légumes sont à disposition dans des AMAP qui proposent une offre variée adaptée aux besoins du consommateur.</li>\n          <li>Apportez les aliments dans les meilleures conditions de fraîcheur grâce à nos variétés sélectionnées.</li>\n          <li>Trouvez l'alimentation de saison la plus délicieuse dans l'alimentation Bio. Découvrez…</li>\n        </ul>\n        <!-- /wp:list -->\n\n        <!-- wp:kadence/advancedbtn {\"uniqueID\":\"saveurs_btn\",\"btnCount\":1} -->\n        <div class=\"wp-block-kadence-advancedbtn kt-btns-wrap\">\n          <div class=\"kt-btn-wrap kt-btn-wrap-0\">\n            <a href=\"#\" class=\"kt-button kt-btn-0-action\" style=\"background-color:#90c940;color:#ffffff;border-radius:4px;padding:12px 24px;font-size:14px;font-weight:600\">Accéder à nos fiches recettes</a>\n          </div>\n        </div>\n        <!-- /wp:kadence/advancedbtn -->\n\n      </div>\n    </div>\n    <!-- /wp:kadence/column -->\n\n  </div>\n</div>\n<!-- /wp:kadence/rowlayout -->\n\n<!-- wp:kadence/rowlayout {\"uniqueID\":\"8_labels_bio\",\"columns\":1,\"colLayout\":\"equal\",\"bgColor\":\"#90c940\",\"paddingTop\":50,\"paddingBottom\":50,\"paddingUnit\":\"px\"} -->\n<div class=\"wp-block-kadence-rowlayout kb-row-layout-wrap kadence-row-8_labels_bio\">\n  <div class=\"kb-row-column-wrap\">\n\n    <!-- wp:kadence/column {\"uniqueID\":\"8_labels_col1\"} -->\n    <div class=\"wp-block-kadence-column kadence-column-8_labels_col1\">\n      <div class=\"kt-inside-inner-col\">\n\n        <!-- wp:kadence/advancedheading {\"uniqueID\":\"labels_pretitle\",\"align\":\"center\",\"color\":\"#ffffff\",\"size\":13,\"sizeType\":\"px\",\"textTransform\":\"italic\"} -->\n        <p style=\"color:#ffffff;font-size:13px;font-style:italic;text-align:center\">Les Certifications des produits</p>\n        <!-- /wp:kadence/advancedheading -->\n\n        <!-- wp:kadence/advancedheading {\"uniqueID\":\"labels_title\",\"align\":\"center\",\"color\":\"#ffffff\",\"size\":26,\"sizeType\":\"px\",\"fontWeight\":\"700\"} -->\n        <h2 class=\"kt-adv-heading wp-block-kadence-advancedheading\" style=\"color:#ffffff;font-size:26px;font-weight:700;text-align:center\">Les labels Bio présents chez JMV</h2>\n        <!-- /wp:kadence/advancedheading -->\n\n        <!-- wp:kadence/rowlayout {\"uniqueID\":\"labels_logos\",\"columns\":4,\"colLayout\":\"equal\",\"paddingTop\":30,\"paddingUnit\":\"px\"} -->\n        <div class=\"wp-block-kadence-rowlayout\" style=\"max-width:800px;margin:0 auto\">\n          <div class=\"kb-row-column-wrap\">\n\n            <!-- wp:kadence/column {\"uniqueID\":\"logo1\"} -->\n            <div class=\"wp-block-kadence-column kadence-column-logo1\">\n              <div class=\"kt-inside-inner-col\" style=\"text-align:center\">\n                <!-- wp:image {\"sizeSlug\":\"thumbnail\"} -->\n                <figure class=\"wp-block-image size-thumbnail\"><img src=\"REMPLACER_URL_LOGO_BIO_1\" alt=\"Label Bio 1\"/></figure>\n                <!-- /wp:image -->\n              </div>\n            </div>\n            <!-- /wp:kadence/column -->\n\n            <!-- wp:kadence/column {\"uniqueID\":\"logo2\"} -->\n            <div class=\"wp-block-kadence-column kadence-column-logo2\">\n              <div class=\"kt-inside-inner-col\" style=\"text-align:center\">\n                <!-- wp:image {\"sizeSlug\":\"thumbnail\"} -->\n                <figure class=\"wp-block-image size-thumbnail\"><img src=\"REMPLACER_URL_LOGO_ECOCERT\" alt=\"Ecocert\"/></figure>\n                <!-- /wp:image -->\n              </div>\n            </div>\n            <!-- /wp:kadence/column -->\n\n            <!-- wp:kadence/column {\"uniqueID\":\"logo3\"} -->\n            <div class=\"wp-block-kadence-column kadence-column-logo3\">\n              <div class=\"kt-inside-inner-col\" style=\"text-align:center\">\n